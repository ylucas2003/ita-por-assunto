  "enunciado_md": "Valor: 0,25 \nSeja um triângulo ABC com lados a, b e c opostos aos ângulos 𝐴̂, 𝐵̂ e 𝐶̂, respectivamente. Os lados \na, b e c formam uma progressão aritmética nesta ordem. Determine a relação correta entre as funções \ntrigonométricas dos ângulos dos vértices desse triângulo.",
  "alternativas": {
    "A": "2𝑠𝑒𝑛(𝐴̂ + 𝐶̂) = 𝑠𝑒𝑛(𝐴̂) + 𝑠𝑒𝑛(𝐶̂)",
    "B": "2𝑐𝑜𝑠(𝐴̂ + 𝐶̂) = 𝑐𝑜𝑠(𝐴̂) + 𝑐𝑜𝑠(𝐶̂)",
    "C": "2𝑠𝑒𝑛(𝐴̂ −𝐶̂) = 𝑠𝑒𝑛(𝐴̂) −𝑠𝑒𝑛(𝐶̂)",
    "D": "2𝑐𝑜𝑠(𝐴̂ −𝐶̂) = 𝑐𝑜𝑠(𝐴̂) −𝑐𝑜𝑠(𝐶̂)",
    "E": "2𝑐𝑜𝑠(𝐴̂ + 𝐶̂) = 𝑠𝑒𝑛(𝐴̂) + 𝑠𝑒𝑛(𝐶̂)"
  },
